# Email/SFTP service
SERVER_PORT=8082

# Switch API
SWITCH_API_BASE_URL=http://localhost:8081
SWITCH_API_ENDPOINT=/api/payment-batch/upload-from-sftp-buzon
SWITCH_API_TIMEOUT=30000

# Logging
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_EC_EDU_ESPE_BANQUITO_EMAILSERVICE=DEBUG

# Actuator
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=always

# Email processor
EMAIL_PROCESSOR_INPUT_DIR=./email-inbox
EMAIL_PROCESSOR_PROCESSED_DIR=./email-processed
EMAIL_PROCESSOR_ERROR_DIR=./email-errors
EMAIL_PROCESSOR_SCAN_INTERVAL=30s
EMAIL_PROCESSOR_ENABLED=true

# SFTP
SFTP_HOST=localhost
SFTP_PORT=22
SFTP_USERNAME=sftpuser
SFTP_PASSWORD=
SFTP_REMOTE_DIRECTORY=/upload
SFTP_LOCAL_DIRECTORY=./sftp-downloads
SFTP_INTEGRATION_ENABLED=false
SFTP_SCHEDULER_ENABLED=true
SFTP_SCHEDULER_INTERVAL=60000
